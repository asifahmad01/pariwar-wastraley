# SQLite database file (created by `npx prisma db push`)
DATABASE_URL="file:./prisma/dev.db"

# Admin login at /admin — required for POST /api/products and POST /api/upload
ADMIN_PASSWORD="change-me-in-production"

# Cloudinary (https://cloudinary.com) — image upload in admin
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional folder prefix for uploads
# CLOUDINARY_FOLDER="pariwar-wastraley/products"
