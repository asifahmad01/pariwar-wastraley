generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String           @id @default(cuid())
  name      String           @unique
  createdAt DateTime         @default(now())
  products  ProductCategory[]
}

model Style {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])
  @@id([productId, categoryId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  nameHi      String?
  category    String?  // legacy single-category string (kept for backward compat)
  style       String
  description String?
  price       Float?
  showPrice   Boolean  @default(true)
  badge       String?
  colors      String   // JSON array of color names
  colorHex    String   // JSON array of hex strings
  sizes       String   // JSON array of size strings
  image       String?
  fabric      String?
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  variants    Variant[]
  categories  ProductCategory[]
}

model Variant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String
  colorHex  String   @default("#722F37")
  size      String
  stockQty  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, color, size])
}
